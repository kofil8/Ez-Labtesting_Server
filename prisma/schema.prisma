generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String     @id @default(uuid()) @db.Uuid
  email                 String     @unique
  password              String
  phoneNumber           String     @unique
  username              String?    @unique @db.VarChar(50)
  profileImage          String?
  bio                   String?    @db.VarChar(500)
  firstName             String     @db.VarChar(100)
  lastName              String     @db.VarChar(100)
  dateOfBirth           DateTime?
  gender                Gender?
  addressLine1          String?    @db.VarChar(255)
  addressLine2          String?    @db.VarChar(255)
  city                  String?    @db.VarChar(100)
  state                 String?    @db.Char(2)
  zipCode               String?    @db.VarChar(10)
  isVerified            Boolean    @default(false)
  emailVerifiedAt       DateTime?
  phoneVerifiedAt       DateTime?
  marketingOptIn        Boolean    @default(false)
  role                  Role       @default(CUSTOMER)
  laboratoryId          String?    @db.Uuid
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?
  lastAction            DateTime?
  lastLogin             DateTime?
  lastPasswordChangedAt DateTime?
  status                UserStatus @default(ACTIVE)
  mfaBackupCodes        String[]   @default([])
  mfaEnabled            Boolean    @default(false)
  mfaSecret             String?
  mfaSetupAt            DateTime?

  laboratory          Laboratory?      @relation(fields: [laboratoryId], references: [id])
  cartItems           CartItem[]
  notifications       Notification[]
  orders              Order[]
  pushTokens          PushToken[]
  reviewHelpfulMarks  ReviewHelpful[]
  sentSupportMessages SupportMessage[] @relation("SupportMessageSender")
  supportTickets      SupportTicket[]
  reviews             TestReview[]

  @@index([role])
  @@index([laboratoryId])
  @@index([status])
}

model TestCategory {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  slug        String   @unique @db.VarChar(120)
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  tests Test[]

  @@index([sortOrder])
  @@index([isActive])
}

model Test {
  id                      String   @id @default(uuid()) @db.Uuid
  testCode                String?  @db.VarChar(50)
  name                    String   @db.VarChar(255)
  slug                    String   @unique @db.VarChar(280)
  description             String?
  testImageUrl            String?  @db.VarChar(500)
  shortDescription        String?  @db.VarChar(500)
  setUpSchedule           String[] @default([]) @db.VarChar(500)
  categoryId              String   @db.Uuid
  specimenType            String?  @db.VarChar(100)
  baseTurnaroundDays      Int?     @db.SmallInt
  isPanel                 Boolean  @default(false)
  cptCode                 String[] @default([]) @db.VarChar(20)
  preparationInstructions String?
  internalNotes           String?
  seoTitle                String?  @db.VarChar(255)
  seoDescription          String?  @db.VarChar(500)
  searchKeywords          String[] @default([])
  requiresFasting         Boolean  @default(false)
  minAge                  Int?     @default(0) @db.SmallInt
  maxAge                  Int?     @default(120) @db.SmallInt
  isActive                Boolean  @default(true)
  isPopular               Boolean  @default(false)
  isPhysicianReviewed     Boolean  @default(false)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  category          TestCategory       @relation(fields: [categoryId], references: [id])
  cartItems         CartItem[]
  labTests          LabTest[]
  orderItems        OrderItem[]
  stateRestrictions StateRestriction[]
  componentOfPanels TestComponent[]    @relation("ComponentOfPanels")
  panelComponents   TestComponent[]    @relation("PanelComponents")
  reviews           TestReview[]

  @@unique([name, categoryId])
  @@index([categoryId])
  @@index([isActive])
  @@index([isPopular])
  @@index([testCode])
  @@index([cptCode])
  @@index([categoryId, isActive])
}

model TestComponent {
  id              String   @id @default(uuid()) @db.Uuid
  panelId         String   @db.Uuid
  componentTestId String   @db.Uuid
  sortOrder       Int      @default(0)
  createdAt       DateTime @default(now())

  panel         Test @relation("PanelComponents", fields: [panelId], references: [id], onDelete: Cascade)
  componentTest Test @relation("ComponentOfPanels", fields: [componentTestId], references: [id], onDelete: Cascade)

  @@unique([panelId, componentTestId])
  @@index([componentTestId])
  @@index([panelId, sortOrder])
}

model Laboratory {
  id                         String   @id @default(uuid()) @db.Uuid
  name                       String   @db.VarChar(255)
  displayName                String?  @db.VarChar(255)
  code                       String   @unique @db.VarChar(20)
  apiEndpoint                String?  @db.VarChar(500)
  apiKeyEncrypted            String?
  integrationType            String?  @db.VarChar(50)
  supportsRealtimeSubmission Boolean  @default(false)
  supportsResultsRetrieval   Boolean  @default(false)
  isActive                   Boolean  @default(true)
  isVisibleToCustomers       Boolean  @default(true)
  sortOrder                  Int      @default(0)
  notes                      String?
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  cartItems         CartItem[]
  drawCenters       DrawCenter[]
  labTests          LabTest[]
  orders            Order[]
  requisitions      Requisition[]
  users             User[]
  stateRestrictions StateRestriction[]

  @@index([isActive])
  @@index([isVisibleToCustomers])
  @@index([sortOrder])
}

model LabTest {
  id                          String   @id @default(uuid()) @db.Uuid
  testId                      String   @db.Uuid
  laboratoryId                String   @db.Uuid
  labTestCode                 String   @db.VarChar(50)
  externalTestId              String?  @db.VarChar(100)
  labCost                     Decimal  @default(0.00) @db.Decimal(10, 2)
  retailPrice                 Decimal  @default(0.00) @db.Decimal(10, 2)
  salePrice                   Decimal? @db.Decimal(10, 2)
  currency                    String   @default("USD") @db.Char(3)
  isAvailable                 Boolean  @default(true)
  isVisible                   Boolean  @default(true)
  turnaroundDaysOverride      Int?     @db.SmallInt
  specimenTypeOverride        String?  @db.VarChar(100)
  patientInstructionsOverride String?
  sortOrder                   Int      @default(0)
  createdAt                   DateTime @default(now())
  updatedAt                   DateTime @updatedAt

  laboratory Laboratory  @relation(fields: [laboratoryId], references: [id])
  test       Test        @relation(fields: [testId], references: [id], onDelete: Cascade)
  cartItems  CartItem[]
  orderItems OrderItem[]

  @@unique([testId, laboratoryId])
  @@unique([laboratoryId, labTestCode])
  @@index([laboratoryId])
  @@index([isAvailable])
  @@index([isVisible])
  @@index([labTestCode])
  @@index([testId, laboratoryId, isAvailable])
}

model StateRestriction {
  id              String          @id @default(uuid()) @db.Uuid
  stateCode       String          @db.Char(2)
  testId          String?         @db.Uuid
  laboratoryId    String?         @db.Uuid
  restrictionType RestrictionType
  notes           String?
  isActive        Boolean         @default(true)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  test       Test?       @relation(fields: [testId], references: [id], onDelete: Cascade)
  laboratory Laboratory? @relation(fields: [laboratoryId], references: [id])

  @@index([stateCode])
  @@index([testId])
  @@index([laboratoryId])
  @@index([stateCode, isActive])
}

model DrawCenter {
  id                   String    @id @default(uuid()) @db.Uuid
  laboratoryId         String    @db.Uuid
  externalCenterId     String?   @db.VarChar(100)
  name                 String    @db.VarChar(255)
  addressLine1         String    @db.VarChar(255)
  addressLine2         String?   @db.VarChar(255)
  city                 String    @db.VarChar(100)
  state                String    @db.Char(2)
  zipCode              String    @db.VarChar(10)
  latitude             Decimal?  @db.Decimal(10, 7)
  longitude            Decimal?  @db.Decimal(10, 7)
  phone                String?   @db.VarChar(20)
  hours                String?
  timezone             String?   @db.VarChar(50)
  acceptsWalkIns       Boolean   @default(true)
  appointmentRequired  Boolean   @default(false)
  isActive             Boolean   @default(true)
  isVisible            Boolean   @default(true)
  normalizedSearchText String?   @db.VarChar(1000)
  metadata             Json?
  deletedAt            DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  laboratory Laboratory @relation(fields: [laboratoryId], references: [id])
  cartItems  CartItem[]
  orders     Order[]

  @@index([laboratoryId])
  @@index([state, city])
  @@index([state])
  @@index([zipCode])
  @@index([isActive])
  @@index([isVisible])
  @@index([deletedAt])
  @@index([latitude, longitude])
}

model CartItem {
  id                 String   @id @default(uuid()) @db.Uuid
  userId             String   @db.Uuid
  testId             String   @db.Uuid
  laboratoryId       String   @db.Uuid
  labTestId          String   @db.Uuid
  drawCenterId       String?  @db.Uuid
  quantity           Int      @default(1)
  currency           String   @default("USD") @db.Char(3)
  baseRetailPrice    Decimal  @default(0.00) @db.Decimal(10, 2)
  effectiveUnitPrice Decimal  @default(0.00) @db.Decimal(10, 2)
  metadata           Json?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  drawCenter DrawCenter? @relation(fields: [drawCenterId], references: [id])
  laboratory Laboratory  @relation(fields: [laboratoryId], references: [id])
  labTest    LabTest     @relation(fields: [labTestId], references: [id])
  test       Test        @relation(fields: [testId], references: [id], onDelete: Cascade)
  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, labTestId])
  @@index([userId])
  @@index([testId])
  @@index([laboratoryId])
  @@index([labTestId])
  @@index([drawCenterId])
}

model Order {
  id                         String                 @id @default(uuid()) @db.Uuid
  userId                     String?                @db.Uuid
  laboratoryId               String                 @db.Uuid
  drawCenterId               String?                @db.Uuid
  orderNumber                String                 @unique @db.VarChar(30)
  currency                   String                 @default("USD") @db.Char(3)
  subtotal                   Decimal                @default(0.00) @db.Decimal(10, 2)
  tax                        Decimal                @default(0.00) @db.Decimal(10, 2)
  processingFee              Decimal                @default(0.00) @db.Decimal(10, 2)
  discount                   Decimal                @default(0.00) @db.Decimal(10, 2)
  total                      Decimal                @default(0.00) @db.Decimal(10, 2)
  paymentStatus              PaymentStatus          @default(PENDING)
  paymentMethodType          PaymentMethodType?
  orderStatus                OrderStatus            @default(PENDING_PAYMENT)
  stripePaymentIntentId      String?                @unique
  stripeChargeId             String?                @unique
  stripePaymentMethodId      String?
  accessSubmissionStatus     AccessSubmissionStatus @default(NOT_SUBMITTED)
  accessOrderId              String?                @unique
  accessClientId             String?
  requisitionPdfUrl          String?
  requisitionPdfPath         String?
  labVisitInstructions       String?
  manualReviewRequired       Boolean                @default(false)
  accessPayloadJson          Json?
  accessResponseJson         Json?
  accessErrorMessage         String?
  paymentSnapshotJson        Json?
  labSubmissionPayloadJson   Json?
  labSubmissionResponseJson  Json?
  labSubmissionErrorCode     String?                @db.VarChar(100)
  labSubmissionErrorMessage  String?
  customerEmailSnapshot      String?                @db.VarChar(255)
  customerPhoneSnapshot      String?                @db.VarChar(20)
  pricingSnapshotJson        Json?
  idempotencyKey             String?                @unique
  labSubmissionAttempts      Int                    @default(0)
  lastLabSubmissionAttemptAt DateTime?
  lastPaymentEventId         String?                @db.VarChar(100)
  paidAt                     DateTime?
  placedAt                   DateTime?
  userConfirmedAt            DateTime?
  submittedToLabAt           DateTime?
  labOrderPlacedAt           DateTime?
  cancelledAt                DateTime?
  refundAmount               Decimal?               @db.Decimal(10, 2)
  refundReason               String?
  createdAt                  DateTime               @default(now())
  updatedAt                  DateTime               @updatedAt
  currentTrackingStep        Int                    @default(1)
  trackingUpdatedAt          DateTime?
  notificationsSent          String[]               @default([])
  lastNotificationAt         DateTime?
  lastTransitionedAt         DateTime?

  drawCenter     DrawCenter?          @relation(fields: [drawCenterId], references: [id])
  laboratory     Laboratory           @relation(fields: [laboratoryId], references: [id])
  user           User?                @relation(fields: [userId], references: [id])
  orderItems     OrderItem[]
  patient        OrderPatient?
  promoCodes     OrderPromoCode[]
  trackingEvents OrderTrackingEvent[]
  requisitions   Requisition[]
  supportTickets SupportTicket[]

  @@index([userId])
  @@index([laboratoryId])
  @@index([drawCenterId])
  @@index([paymentStatus])
  @@index([paymentMethodType])
  @@index([orderStatus])
  @@index([accessSubmissionStatus])
  @@index([manualReviewRequired])
  @@index([paidAt])
  @@index([createdAt])
}

model OrderPatient {
  id             String          @id @default(uuid()) @db.Uuid
  orderId        String          @unique @db.Uuid
  relationToUser PatientRelation @default(SELF)
  firstName      String          @db.VarChar(100)
  lastName       String          @db.VarChar(100)
  dateOfBirth    DateTime?
  gender         Gender?
  phoneNumber    String?         @db.VarChar(20)
  email          String?         @db.VarChar(255)
  addressLine1   String?         @db.VarChar(255)
  addressLine2   String?         @db.VarChar(255)
  city           String?         @db.VarChar(100)
  state          String?         @db.Char(2)
  zipCode        String?         @db.VarChar(10)
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
}

model OrderItem {
  id                  String   @id @default(uuid()) @db.Uuid
  orderId             String   @db.Uuid
  testId              String   @db.Uuid
  labTestId           String   @db.Uuid
  labTestCode         String   @db.VarChar(50)
  testName            String   @db.VarChar(255)
  laboratoryName      String   @db.VarChar(255)
  quantity            Int      @default(1)
  baseRetailPrice     Decimal  @default(0.00) @db.Decimal(10, 2)
  effectiveUnitPrice  Decimal  @default(0.00) @db.Decimal(10, 2)
  discountAmount      Decimal  @default(0.00) @db.Decimal(10, 2)
  price               Decimal  @default(0.00) @db.Decimal(10, 2)
  labCost             Decimal  @default(0.00) @db.Decimal(10, 2)
  currency            String   @default("USD") @db.Char(3)
  pricingSnapshotJson Json?
  createdAt           DateTime @default(now())

  order        Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  test         Test          @relation(fields: [testId], references: [id])
  labTest      LabTest       @relation(fields: [labTestId], references: [id])
  requisitions Requisition[]

  @@index([orderId])
  @@index([testId])
  @@index([labTestId])
}

model Requisition {
  id                     String            @id @default(uuid()) @db.Uuid
  orderId                String            @db.Uuid
  orderItemId            String?           @db.Uuid
  laboratoryId           String?           @db.Uuid
  providerCode           String?           @db.VarChar(30)
  requisitionNumber      String?           @db.VarChar(50)
  requisitionPdfUrl      String?           @db.VarChar(500)
  requisitionPdfPath     String?           @db.VarChar(500)
  fileStorageKey         String?           @db.VarChar(500)
  downloadFileName       String?           @db.VarChar(255)
  labOrderId             String?           @db.VarChar(100)
  status                 RequisitionStatus @default(PENDING)
  rawPayloadJson         Json?
  rawResponseJson        Json?
  fileMetadataJson       Json?
  drawCenterSnapshotJson Json?
  submittedAt            DateTime?
  readyAt                DateTime?
  failedAt               DateTime?
  resultsReadyAt         DateTime?
  createdAt              DateTime          @default(now())
  updatedAt              DateTime          @updatedAt

  laboratory Laboratory? @relation(fields: [laboratoryId], references: [id])
  order      Order       @relation(fields: [orderId], references: [id], onDelete: Cascade)
  orderItem  OrderItem?  @relation(fields: [orderItemId], references: [id])

  @@index([orderId])
  @@index([orderItemId])
  @@index([laboratoryId])
  @@index([status])
  @@index([labOrderId])
  @@index([requisitionNumber])
}

model PromoCode {
  id                  String               @id @default(uuid()) @db.Uuid
  code                String               @unique @db.VarChar(50)
  discountType        DiscountType
  pricingStrategy     PromoPricingStrategy @default(PRICING_FLOOR)
  status              PromoCodeStatus      @default(DRAFT)
  discountValue       Decimal              @default(0.00) @db.Decimal(10, 2)
  minOrder            Decimal?             @db.Decimal(10, 2)
  minimumMarginAmount Decimal?             @db.Decimal(10, 2)
  perUserLimit        Int?
  maxUses             Int?
  usedCount           Int                  @default(0)
  startsAt            DateTime?
  expiresAt           DateTime?
  isActive            Boolean              @default(true)
  deletedAt           DateTime?
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt

  orderPromoCodes OrderPromoCode[]

  @@index([isActive])
  @@index([expiresAt])
  @@index([status])
  @@index([deletedAt])
}

model OrderPromoCode {
  id              String               @id @default(uuid()) @db.Uuid
  orderId         String               @db.Uuid
  promoCodeId     String               @db.Uuid
  appliedCode     String               @db.VarChar(50)
  discountType    DiscountType
  discountValue   Decimal              @default(0.00) @db.Decimal(10, 2)
  pricingStrategy PromoPricingStrategy @default(PRICING_FLOOR)
  discountAmount  Decimal              @default(0.00) @db.Decimal(10, 2)
  createdAt       DateTime             @default(now())

  order     Order     @relation(fields: [orderId], references: [id], onDelete: Cascade)
  promoCode PromoCode @relation(fields: [promoCodeId], references: [id])

  @@index([orderId])
  @@index([promoCodeId])
}

model TestReview {
  id                 String   @id @default(uuid()) @db.Uuid
  testId             String   @db.Uuid
  userId             String   @db.Uuid
  rating             Int      @db.SmallInt
  title              String   @db.VarChar(200)
  comment            String   @db.VarChar(1000)
  isVerifiedPurchase Boolean  @default(false)
  isPublished        Boolean  @default(true)
  isFlagged          Boolean  @default(false)
  helpfulCount       Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  helpfulMarks ReviewHelpful[]
  test         Test            @relation(fields: [testId], references: [id], onDelete: Cascade)
  user         User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([testId, userId])
  @@index([testId])
  @@index([userId])
  @@index([rating])
  @@index([createdAt])
}

model ReviewHelpful {
  id        String   @id @default(uuid()) @db.Uuid
  reviewId  String   @db.Uuid
  userId    String   @db.Uuid
  createdAt DateTime @default(now())

  review TestReview @relation(fields: [reviewId], references: [id], onDelete: Cascade)
  user   User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([reviewId, userId])
  @@index([reviewId])
  @@index([userId])
}

model OrderTrackingEvent {
  id             String                 @id @default(uuid()) @db.Uuid
  orderId        String                 @db.Uuid
  step           Int                    @default(0)
  eventType      OrderTrackingEventType
  actorType      TrackingActorType      @default(SYSTEM)
  actorId        String?                @db.VarChar(100)
  previousStatus OrderStatus?
  nextStatus     OrderStatus?
  message        String?                @db.VarChar(500)
  metadata       Json?
  occurredAt     DateTime               @default(now())
  createdAt      DateTime               @default(now())

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@index([orderId, createdAt])
  @@index([eventType, createdAt])
}

model SupportTicket {
  id                      String                  @id @default(uuid()) @db.Uuid
  ticketNumber            String                  @unique @db.VarChar(30)
  userId                  String                  @db.Uuid
  orderId                 String?                 @db.Uuid
  subject                 String                  @db.VarChar(200)
  category                SupportCategory         @default(GENERAL)
  priority                SupportPriority         @default(MEDIUM)
  status                  SupportTicketStatus     @default(OPEN)
  reasonCode              SupportTicketReasonCode @default(GENERAL_REQUEST)
  notes                   String?
  failureContextJson      Json?
  assigneeUserId          String?                 @db.Uuid
  resolvedByUserId        String?                 @db.Uuid
  resolutionNotes         String?
  responseTarget          DateTime
  manualReviewRequestedAt DateTime?
  respondedAt             DateTime?
  resolvedAt              DateTime?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt

  messages SupportMessage[]
  order    Order?           @relation(fields: [orderId], references: [id])
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([priority, status])
  @@index([createdAt])
  @@index([orderId])
  @@index([reasonCode, status])
}

model SupportMessage {
  id         String            @id @default(uuid()) @db.Uuid
  ticketId   String            @db.Uuid
  senderId   String            @db.Uuid
  senderType SupportSenderType
  message    String
  createdAt  DateTime          @default(now())

  sender User          @relation("SupportMessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId, createdAt])
  @@index([senderId])
}

model PushToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String?  @db.Uuid
  token     String   @unique
  platform  String?
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Notification {
  id           String               @id @default(uuid()) @db.Uuid
  userId       String               @db.Uuid
  type         NotificationType
  title        String               @db.VarChar(200)
  body         String
  data         Json?
  priority     NotificationPriority @default(MEDIUM)
  isRead       Boolean              @default(false)
  readAt       DateTime?
  deliveredVia String[]             @default([])
  sentAt       DateTime             @default(now())
  expiresAt    DateTime
  createdAt    DateTime             @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead, createdAt])
  @@index([expiresAt])
  @@index([priority, createdAt])
  @@index([sentAt])
}

model NotificationTemplate {
  id           String           @id @default(uuid()) @db.Uuid
  type         NotificationType @unique
  name         String           @db.VarChar(200)
  description  String?
  emailSubject String           @db.VarChar(200)
  emailBody    String
  pushTitle    String           @db.VarChar(200)
  pushBody     String           @db.VarChar(500)
  variables    Json             @default("[]")
  isActive     Boolean          @default(true)
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  @@index([type])
}

model AuditLog {
  id            String   @id @default(uuid()) @db.Uuid
  adminId       String   @db.Uuid
  adminName     String
  action        String   @db.VarChar(50)
  resource      String   @db.VarChar(100)
  resourceId    String   @db.VarChar(100)
  details       String
  changesBefore String?
  changesAfter  String?
  ipAddress     String?  @db.VarChar(50)
  userAgent     String?
  status        String   @default("SUCCESS") @db.VarChar(20)
  errorMessage  String?
  createdAt     DateTime @default(now())

  @@index([adminId])
  @@index([resource])
  @@index([action])
  @@index([createdAt])
}

enum Role {
  SUPER_ADMIN
  ADMIN
  LAB_PARTNER
  CUSTOMER
}

enum UserStatus {
  ACTIVE
  DISABLED
  BLOCKED
}

enum Gender {
  MALE
  FEMALE
  NON_BINARY
  PREFER_NOT_TO_SAY
  OTHER
}

enum NotificationType {
  ORDER_CREATED
  ORDER_CONFIRMED
  ORDER_CANCELLED
  ORDER_COMPLETED
  ORDER_IN_PROGRESS
  RESULTS_READY
  RESULTS_ABNORMAL
  APPOINTMENT_SCHEDULED
  APPOINTMENT_REMINDER
  NEW_DISCOUNT
  DISCOUNT_EXPIRING
  LAB_CENTER_UPDATED
  LAB_CENTER_CLOSED
  SYSTEM_ALERT
  ADMIN_ANNOUNCEMENT
  WELCOME
